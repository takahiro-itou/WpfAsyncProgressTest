<Window x:Class="WpfAsyncProgressTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfAsyncProgressTest"
        mc:Ignorable="d"
        Title="MainWindow" Height="240" Width="800">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Menu1(_A)">
                <MenuItem Header="Menu 1-1" />
                <MenuItem Header="Menu 1-2" />
                <Separator />
                <MenuItem Header="Menu 1-3">
                    <MenuItem Header="Menu 1-3-1" />
                    <MenuItem Header="Menu 1-3-2" />
                </MenuItem>
            </MenuItem>
            <MenuItem Header="Menu2 (_B)" />
        </Menu>
        <StackPanel Orientation="Vertical">
            <StackPanel Orientation="Horizontal">
                <Button Content="Run" Width="128" Height="64" Margin="8,8,8,8"
                    Command="{Binding HeavyTaskCommand}"
                />
                <Button Content="Pause"
                    Width="128" Height="64" Margin="8,8,8,8"
                    Command="{Binding PauseCommand}"
                />
            </StackPanel>
            <Grid>
            <ProgressBar x:Name="MyProgress"
                Width="400" Height="32" Margin="8,8,8,8"
                Minimum="0" Maximum="100"
                Value="{Binding ProgressValue, Mode=OneWay}"
            />
            <TextBlock
                Width="400" Margin="8,8,8,8"
                Text="{Binding ProgressValue}" />
            </Grid>
            <StackPanel Orientation="Horizontal">
            <TextBlock x:Name="ResultText" Text="{Binding ResultValue}"
                Width="128" Height="64" Margin="8,8,8,8"
            />
                <TextBlock Text="{Binding IsPaused}"
                    Width="128" Height="64" Margin="8,8,8,8"
                />
            </StackPanel>
        </StackPanel>
    </DockPanel>
</Window>
