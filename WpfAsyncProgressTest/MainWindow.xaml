<Window x:Class="WpfAsyncProgressTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfAsyncProgressTest"
        mc:Ignorable="d"
        Title="MainWindow" Height="240" Width="800">
    <Grid>
        <StackPanel Orientation="Vertical">
            <Button Content="Run" Width="128" Height="64" Margin="8,8,8,8"
                Click="OnButtonClickAsync" />
            <ProgressBar Width="400" Height="32" Minimum="0" Maximum="100" Value="50" Margin="8,8,8,8" />
            <TextBlock x:Name="ResultText" />
        </StackPanel>
    </Grid>
</Window>
